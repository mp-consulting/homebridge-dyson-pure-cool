{
  "name": "@mp-consulting/homebridge-dyson-pure-cool",
  "displayName": "Dyson Pure Cool",
  "type": "module",
  "version": "1.0.29",
  "private": false,
  "description": "Homebridge plugin for Dyson Pure Cool air purifiers and fans. Control fan speed, monitor air quality, temperature, and humidity via HomeKit.",
  "author": "MP Consulting",
  "license": "MIT",
  "homepage": "https://github.com/mp-consulting/homebridge-dyson-pure-cool#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mp-consulting/homebridge-dyson-pure-cool.git"
  },
  "bugs": {
    "url": "https://github.com/mp-consulting/homebridge-dyson-pure-cool/issues"
  },
  "funding": {
    "type": "paypal",
    "url": "https://paypal.me/mickaelpalma"
  },
  "keywords": [
    "homebridge-plugin",
    "homebridge",
    "homekit",
    "dyson",
    "pure-cool",
    "air-purifier",
    "fan",
    "air-quality",
    "temperature",
    "humidity",
    "smart-home"
  ],
  "main": "dist/index.js",
  "engines": {
    "node": "^20.18.0 || ^22.10.0 || ^24.0.0",
    "homebridge": "^1.8.0 || ^2.0.0-beta.0"
  },
  "scripts": {
    "copy:ui-kit": "mkdir -p homebridge-ui/public/lib && cp node_modules/@mp-consulting/homebridge-ui-kit/dist/kit.css homebridge-ui/public/lib/ && cp node_modules/@mp-consulting/homebridge-ui-kit/dist/kit.js homebridge-ui/public/lib/",
    "build": "npm run copy:ui-kit && rimraf ./dist && tsc",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run lint && npm run build",
    "watch": "npm run build && npm link && nodemon"
  },
  "dependencies": {
    "@homebridge/plugin-ui-utils": "^2.2.3",
    "bonjour-service": "^1.3.0",
    "class-validator": "^0.15.1",
    "homebridge-lib": "^8.0.0",
    "mqtt": "^5.14.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@mp-consulting/homebridge-ui-kit": "^1.0.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.2.1",
    "homebridge": "^2.0.0-beta.55",
    "homebridge-config-ui-x": "^5.19.0",
    "nodemon": "^3.1.11",
    "rimraf": "^6.1.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.53.1",
    "vitest": "^4.0.18"
  },
  "files": [
    "dist",
    "homebridge-ui",
    "config.schema.json"
  ]
}
